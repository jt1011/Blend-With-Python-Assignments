{
  "manifest_version": 3,
  "name": "X Feed Capture Agent",
  "version": "0.1.0",
  "description": "Capture X/Twitter feed posts with safe auto-scroll and export JSON for LinkedIn idea generation.",
  "permissions": [
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "X Feed Capture Agent",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
